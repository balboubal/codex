# Copy this file to .env.local for local development with `vercel dev`.
# In production, set these as Environment Variables in your Vercel project settings.

# Your Supabase project URL, e.g. https://abcdefghijklmnop.supabase.co
SUPABASE_URL=

# Supabase service_role key.
# SECRET — server-side only. Never expose this to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# The passphrase your DM types to unlock editing. Choose anything you like.
DM_PASSWORD=

# Any long random string used to sign the login cookie.
# Generate one, e.g.:  openssl rand -base64 32
SESSION_SECRET=
